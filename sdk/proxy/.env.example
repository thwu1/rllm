# RLLM LiteLLM Proxy Environment Variables

# LLM Provider API Keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
COHERE_API_KEY=...
GOOGLE_API_KEY=...

# Proxy Configuration
RLLM_PROXY_CONFIG=./config.yaml
RLLM_LOG_DIR=./logs
RLLM_ENABLE_LOGPROBS=true
RLLM_ENABLE_PROMPT_TOKENS=true

# Server Settings
RLLM_HOST=0.0.0.0
RLLM_PORT=8000
RLLM_WORKERS=4
RLLM_LOG_LEVEL=info

# Optional: Redis for caching
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
